{
  "name": "@phos/db",
  "version": "0.1.0",
  "private": true,
  "main": "generated/client/index.js",
  "types": "generated/client/index.d.ts",
  "exports": {
    ".": {
      "types": "./generated/client/index.d.ts",
      "default": "./generated/client/index.js"
    }
  },
  "scripts": {
    "build": "prisma generate --generator client",
    "db:generate": "prisma generate --generator client",
    "db:erd": "prisma generate --generator markdown",
    "db:migrate:dev": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "typecheck": "sh -c 'DATABASE_URL=postgresql://phos:phos@localhost:5432/phos?schema=public prisma validate'",
    "clean": "rm -rf generated"
  },
  "dependencies": {
    "@prisma/client": "^7.5.0"
  },
  "devDependencies": {
    "dotenv": "^17.3.1",
    "prisma": "^7.5.0",
    "prisma-markdown": "^4.0.0"
  }
}
