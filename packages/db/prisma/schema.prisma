generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SessionMode {
  LIVE_BOOTH
}

enum SessionStatus {
  active
  rendered
  finalized
  deleted
}

enum DeletionStatus {
  active
  export_requested
  delete_requested
  deleted
}

model Session {
  sessionId            String         @id
  mode                 SessionMode
  status               SessionStatus  @default(active)
  selectedFrameId      String
  selectedShotAssetIds String[]
  editState            Json
  mediaPreset          String         @default("default")
  retentionExpiresAt   DateTime
  trainingUsed         Boolean        @default(false)
  consentVersion       String?
  deletionStatus       DeletionStatus @default(active)
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
}
