/// 프라이버시 결정 감사를 위한 불변 동의 스냅샷.
///
/// @namespace PrivacyControls
/// @erd SessionFlow
model Consent {
  /// 동의 스냅샷 식별자.
  consentId String @id

  /// 상위 세션 식별자.
  sessionId String

  /// 상위 세션 관계.
  session Session @relation(fields: [sessionId], references: [sessionId], onDelete: Cascade, onUpdate: Cascade)

  /// 필수 서비스 약관 동의 여부.
  serviceConsentAccepted Boolean

  /// 선택적 모델 학습 동의 여부.
  trainingOptIn Boolean @default(false)

  /// 사용자에게 표시된 동의 버전.
  consentVersion String

  /// 스냅샷 생성 시각.
  createdAt DateTime @default(now())

  @@index([sessionId])
  @@index([sessionId, consentVersion])
}

/// 사용자가 세션 삭제와 전달 산출물 무효화를 요청한 기록.
///
/// @namespace PrivacyControls
/// @erd SessionFlow
model DeletionRequest {
  /// 삭제 요청 식별자.
  requestId String @id

  /// 상위 세션 식별자.
  sessionId String

  /// 상위 세션 관계.
  session Session @relation(fields: [sessionId], references: [sessionId], onDelete: Cascade, onUpdate: Cascade)

  /// 삭제 워크플로 상태.
  status RequestStatus @default(requested)

  /// 요청 생성 시각.
  createdAt DateTime @default(now())

  /// 완료 시각.
  completedAt DateTime?

  @@index([sessionId])
  @@index([status])
}
