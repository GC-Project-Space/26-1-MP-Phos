enum ShareLinkStatus {
  active
  expired
  revoked
}

enum RequestStatus {
  requested
  completed
  failed
}

/// 렌더링된 세션 결과물을 내려받을 수 있는 공유 링크.
///
/// @namespace DeliveryLifecycle
/// @erd SessionFlow
model ShareLink {
  /// 공유 링크 식별자.
  shareLinkId String @id

  /// 상위 세션 식별자.
  sessionId String

  /// 상위 세션 관계.
  session Session @relation(fields: [sessionId], references: [sessionId], onDelete: Cascade, onUpdate: Cascade)

  /// 링크 사용 가능 상태.
  status ShareLinkStatus @default(active)

  /// 최종 사용자에게 제공되는 공개 URL.
  url String @unique

  /// 세션 보관 정책에 따라 제한되는 만료 시각.
  expiresAt DateTime

  /// 링크 생성 시각.
  createdAt DateTime @default(now())

  @@index([sessionId])
  @@index([status])
  @@index([expiresAt])
}

/// 삭제 전에 세션을 내보내기 위한 요청.
///
/// @namespace DeliveryLifecycle
/// @erd SessionFlow
model ExportRequest {
  /// 내보내기 요청 식별자.
  exportRequestId String @id

  /// 상위 세션 식별자.
  sessionId String

  /// 상위 세션 관계.
  session Session @relation(fields: [sessionId], references: [sessionId], onDelete: Cascade, onUpdate: Cascade)

  /// 내보내기 워크플로 상태.
  status RequestStatus @default(requested)

  /// 요청 생성 시각.
  createdAt DateTime @default(now())

  /// 완료 시각.
  completedAt DateTime?

  @@index([sessionId])
  @@index([status])
}
