enum AssetType {
  photo
  video
}

enum AssetRole {
  raw_shot
  final_photo
  making_video
}

enum AssetStatus {
  available
  expired
  deleted
}

/// 세션 내에서 생성되거나 업로드된 미디어.
///
/// @namespace MediaAssets
/// @erd SessionFlow
model Asset {
  /// 변경되지 않는 에셋 식별자.
  assetId String @id

  /// 소유 세션 식별자.
  sessionId String

  /// 상위 세션 관계.
  session Session @relation(fields: [sessionId], references: [sessionId], onDelete: Cascade, onUpdate: Cascade)

  /// 물리적 미디어 종류.
  assetType AssetType

  /// 세션 흐름 내 기능적 역할.
  assetRole AssetRole

  /// 클라이언트에 제공되는 MIME 타입.
  mimeType String

  /// 사용 가능 상태.
  status AssetStatus @default(available)

  /// 비디오 에셋의 선택적 재생 길이.
  durationMs Int?

  /// 생성 시각.
  createdAt DateTime @default(now())

  /// 이 에셋을 최종 사진으로 참조하는 세션.
  finalPhotoFor Session? @relation("FinalPhotoAsset")

  /// 이 에셋을 메이킹 영상으로 참조하는 세션.
  makingVideoFor Session? @relation("MakingVideoAsset")

  /// 렌더링에 사용되는 순서 기반 선택 레코드.
  selectedInSessions SessionShotSelection[]

  @@index([sessionId])
  @@index([sessionId, assetRole])
  @@index([sessionId, assetType])
  @@index([status])
}

/// 렌더링용으로 선택된 원본 컷 순서 스냅샷.
///
/// @namespace MediaAssets
/// @erd SessionFlow
model SessionShotSelection {
  /// 상위 세션 식별자.
  sessionId String

  /// 선택된 원본 컷 에셋 식별자.
  assetId String

  /// 0부터 시작하는 렌더 순서.
  position Int

  session Session @relation(fields: [sessionId], references: [sessionId], onDelete: Cascade, onUpdate: Cascade)
  asset   Asset   @relation(fields: [assetId], references: [assetId], onDelete: Cascade, onUpdate: Cascade)

  @@id([sessionId, assetId])
  @@unique([sessionId, position])
  @@index([assetId])
}
