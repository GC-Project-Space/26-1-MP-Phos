enum FrameLayout {
  FOUR_CUT @map("4_cut")
  SIX_CUT  @map("6_cut")
}

/// 세션에서 사용할 수 있는 프레임 카탈로그 항목.
///
/// @namespace FrameCatalog
/// @erd SessionFlow
model Frame {
  /// 변경되지 않는 프레임 식별자.
  frameId String @id

  /// 클라이언트에 노출되는 레이아웃 변형.
  layoutType FrameLayout

  /// 사람이 읽기 쉬운 프레임 제목.
  title String

  /// 프레임에서 사용할 수 있는 촬영 슬롯 수.
  slotCount Int

  /// 현재 선택 가능한 프레임인지 여부.
  isActive Boolean @default(true)

  sessions Session[]
}
