enum SessionMode {
  LIVE_BOOTH
}

enum SessionStatus {
  active
  rendered
  finalized
  deleted
}

enum DeletionStatus {
  active
  export_requested
  delete_requested
  deleted
}

/// 익명 세션의 핵심 집계 모델.
///
/// @namespace SessionFlow
/// @erd FrameCatalog
/// @erd MediaAssets
/// @erd PrivacyControls
/// @erd DeliveryLifecycle
model Session {
  /// 익명 세션 식별자.
  sessionId String @id

  /// 촬영 경험에 사용되는 세션 모드.
  mode SessionMode

  /// 세션 생명주기 상태.
  status SessionStatus @default(active)

  /// 선택한 프레임 식별자.
  selectedFrameId String

  /// 선택한 프레임 관계.
  selectedFrame Frame @relation(fields: [selectedFrameId], references: [frameId], onDelete: Restrict, onUpdate: Cascade)

  /// 현재 API 구현과의 하위 호환을 위한 스냅샷.
  /// 순서가 있는 관계형 모델을 계속 최종 기준으로 삼아야 한다.
  selectedShotAssetIds String[]

  /// 선택한 원본 컷의 렌더 입력 순서.
  selectedShots SessionShotSelection[]

  /// 가벼운 편집을 위한 유연한 편집 페이로드.
  editState Json

  /// 디바이스 등급 최적화에 적용되는 미디어 프리셋.
  mediaPreset String @default("default")

  /// 렌더링된 최종 사진 에셋.
  finalPhotoAssetId String? @unique

  /// 렌더링된 최종 사진 에셋과의 관계.
  finalPhotoAsset Asset? @relation("FinalPhotoAsset", fields: [finalPhotoAssetId], references: [assetId], onDelete: SetNull, onUpdate: Cascade)

  /// 기록된 메이킹 영상 에셋.
  makingVideoAssetId String? @unique

  /// 촬영된 메이킹 영상 에셋과의 관계.
  makingVideoAsset Asset? @relation("MakingVideoAsset", fields: [makingVideoAssetId], references: [assetId], onDelete: SetNull, onUpdate: Cascade)

  /// 프라이버시 정리를 위한 보관 만료 시각.
  retentionExpiresAt DateTime

  /// 이 세션의 학습 데이터가 사용되었는지 여부.
  trainingUsed Boolean @default(false)

  /// 최신 활성 동의 버전 스냅샷.
  consentVersion String?

  /// 프라이버시/삭제 워크플로 상태.
  deletionStatus DeletionStatus @default(active)

  /// 세션 생성 시각.
  createdAt DateTime @default(now())

  /// 마지막 변경 시각.
  updatedAt DateTime @updatedAt

  /// 세션이 소유한 에셋.
  assets Asset[]

  /// 세션에 연결된 동의 스냅샷.
  consents Consent[]

  /// 세션에 발급된 공유 링크.
  shareLinks ShareLink[]

  /// 세션의 내보내기 요청.
  exportRequests ExportRequest[]

  /// 세션의 삭제 요청.
  deletionRequests DeletionRequest[]

  @@index([selectedFrameId])
  @@index([status])
  @@index([deletionStatus])
  @@index([retentionExpiresAt])
}
