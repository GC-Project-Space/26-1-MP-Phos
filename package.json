{
  "name": "phos",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "pnpm dev:api",
    "dev:mobile": "cd apps/mobile && flutter run",
    "mobile:android": "cd apps/mobile && flutter run -d android",
    "mobile:ios": "cd apps/mobile && flutter run -d ios",
    "mobile:web": "cd apps/mobile && flutter run -d chrome",
    "mobile:test": "cd apps/mobile && flutter test",
    "mobile:analyze": "cd apps/mobile && flutter analyze",
    "dev:api": "pnpm --filter api start:dev",
    "db:generate": "pnpm --filter api db:generate",
    "db:erd": "pnpm --filter api db:erd",
    "db:migrate:dev": "pnpm --filter api db:migrate:dev",
    "db:migrate:deploy": "pnpm --filter api db:migrate:deploy",
    "db:push": "pnpm --filter api db:push",
    "db:studio": "pnpm --filter api db:studio",
    "db:validate": "pnpm --filter api db:validate",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down",
    "build": "pnpm --filter api db:generate && pnpm --filter api build",
    "typecheck": "pnpm --filter api db:generate && pnpm --filter api db:validate && pnpm --filter api typecheck",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "test": "turbo run test",
    "test:e2e": "pnpm --filter api test:e2e",
    "clean": "turbo run clean && rm -rf node_modules apps/*/node_modules"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "turbo": "^2.8.21",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.57.2"
  }
}
