{
  "name": "phos",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "turbo run dev --parallel --filter=mobile --filter=api",
    "dev:mobile": "pnpm --filter mobile start",
    "mobile:android:run": "pnpm --filter mobile run android",
    "mobile:android:start": "pnpm --filter mobile exec expo start --dev-client --android",
    "mobile:android": "pnpm mobile:android:run && pnpm mobile:android:start",
    "mobile:ios:run": "pnpm --filter mobile exec expo run:ios",
    "mobile:ios:start": "pnpm --filter mobile exec expo start --dev-client --ios",
    "mobile:ios": "pnpm mobile:ios:run && pnpm mobile:ios:start",
    "dev:api": "pnpm --filter api start:dev",
    "db:generate": "pnpm --filter @phos/db db:generate",
    "db:erd": "pnpm --filter @phos/db db:erd",
    "db:migrate:dev": "pnpm --filter @phos/db db:migrate:dev",
    "db:migrate:deploy": "pnpm --filter @phos/db db:migrate:deploy",
    "db:push": "pnpm --filter @phos/db db:push",
    "db:studio": "pnpm --filter @phos/db db:studio",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down",
    "build": "pnpm --filter @phos/db build && pnpm --filter @phos/shared build && pnpm --filter @phos/backend-contracts build && turbo run build --filter=api",
    "typecheck": "pnpm --filter @phos/db build && pnpm --filter @phos/shared build && pnpm --filter @phos/backend-contracts build && turbo run typecheck",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "test": "turbo run test",
    "test:smoke": "pnpm --filter mobile test:smoke",
    "test:e2e": "pnpm --filter api test:e2e",
    "clean": "turbo run clean && rm -rf node_modules apps/*/node_modules packages/*/node_modules"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.5.0",
    "prettier": "^3.8.2",
    "turbo": "^2.9.6",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1"
  }
}
