{
  "name": "phos",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "turbo run dev --parallel --filter=mobile --filter=api",
    "dev:mobile": "pnpm --filter mobile start",
    "dev:api": "pnpm --filter api start:dev",
    "db:generate": "pnpm --filter @phos/db db:generate",
    "db:migrate:dev": "pnpm --filter @phos/db db:migrate:dev",
    "db:push": "pnpm --filter @phos/db db:push",
    "db:studio": "pnpm --filter @phos/db db:studio",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down",
    "build": "pnpm --filter @phos/db build && pnpm --filter @phos/shared build && pnpm --filter @phos/backend-contracts build && turbo run build --filter=api",
    "typecheck": "pnpm --filter @phos/db build && pnpm --filter @phos/shared build && pnpm --filter @phos/backend-contracts build && turbo run typecheck",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "test": "turbo run test",
    "test:e2e": "pnpm --filter api test:e2e",
    "clean": "turbo run clean && rm -rf node_modules apps/*/node_modules packages/*/node_modules"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "turbo": "^2.8.20",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1"
  }
}
